{
  "name": "@mwp13/asx",
  "version": "0.2.1",
  "description": "Agent-first Asana CLI with schema introspection",
  "license": "MIT",
  "author": "mwpryer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwpryer/asx.git"
  },
  "bin": {
    "asx": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "format": "bun run lint:fix && bun run fmt:fix"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "valibot": "^1.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  },
  "engines": {
    "node": ">=24"
  }
}
